<div class="page-heading mb-4">
  <div>
    <h2>الإعدادات</h2>
    <p class="text-muted">غيّر معلومات تسجيل الدخول بأمان.</p>
  </div>
</div>

<div class="card p-4">
  <% if (saved) { %>
    <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>الإعدادات saved successfully.</div>
  <% } %>
  <form method="POST" action="/settings">
    <div class="mb-4">
      <label class="form-label">New اسم المستخدم</label>
      <input type="text" name="newاسم المستخدم" class="form-control" value="<%= user.username %>" required />
    </div>
    <div class="mb-4">
      <label class="form-label">New كلمة المرور</label>
      <input type="password" name="newكلمة المرور" class="form-control" required />
    </div>
    <button class="btn btn-primary"><i class="bi bi-save me-2"></i>حفظ Changes</button>
  </form>
</div>
