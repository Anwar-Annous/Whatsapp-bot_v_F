<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-..."
      crossorigin="anonymous"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <div class="sidebar-brand px-4 py-4 text-white">
          <div class="brand-title">واتساب <span>التحكم</span></div>
          <div class="brand-subtitle">مركز الأعمال</div>
        </div>

        <nav class="sidebar-menu px-2">
          <a class="sidebar-link <%= page === 'dashboard' ? 'active' : '' %>" href="/">
            <i class="bi bi-speedometer2"></i> لوحة التحكم
          </a>
          <a class="sidebar-link <%= page === 'accounts' ? 'active' : '' %>" href="/accounts">
            <i class="bi bi-people"></i> الحسابات
          </a>
          <a class="sidebar-link <%= page === 'contacts' ? 'active' : '' %>" href="/contacts">
            <i class="bi bi-person-lines-fill"></i> جهات الاتصال
          </a>
          <a class="sidebar-link <%= page === 'broadcast' ? 'active' : '' %>" href="/broadcast">
            <i class="bi bi-megaphone"></i> إرسال جماعي
          </a>
          <a class="sidebar-link <%= page === 'flows' ? 'active' : '' %>" href="/flows">
            <i class="bi bi-arrow-repeat"></i> السيناريوهات
          </a>
          <a class="sidebar-link <%= page === 'conversations' ? 'active' : '' %>" href="/conversations">
            <i class="bi bi-chat-dots"></i> المحادثات
          </a>
          <a class="sidebar-link <%= page === 'settings' ? 'active' : '' %>" href="/settings">
            <i class="bi bi-gear"></i> الإعدادات
          </a>
        </nav>

        <div class="sidebar-footer px-4 py-3">
          <a class="logout-link" href="/logout">
            <i class="bi bi-box-arrow-right"></i> Logout
          </a>
        </div>
      </aside>

      <div class="main-content">
        <header class="topbar d-flex justify-content-between align-items-center px-4 py-3">
          <button class="mobile-menu-btn" id="mobileMenuBtn" type="button">
            <i class="bi bi-list"></i>
          </button>
          <div>
            <span class="topbar-title">واتساب لوحة التحكم</span>
            <div class="topbar-subtitle">دبّر الحسابات، المحادثات، السيناريوهات، جهات الاتصال والإرسال الجماعي</div>
          </div>
          <div class="topbar-actions">
            <span class="status-badge"><i class="bi bi-circle-fill"></i> جاهز</span>
          </div>
        </header>

        <main class="content-wrapper p-4">
          <%- body %>
        </main>
      </div>
    </div>

    <div id="confirmحذفModal" class="confirm-modal" aria-hidden="true">
      <div class="confirm-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="confirmحذفTitle">
        <div class="confirm-modal-content">
          <div class="confirm-modal-header">
            <h5 id="confirmحذفTitle">تأكيد الحذف</h5>
            <button type="button" class="confirm-modal-close" aria-label="Close">&times;</button>
          </div>
          <div class="confirm-modal-body">
            <p id="confirmحذفالرسالة">واش متأكد بغيتي تحذف هاد العنصر؟</p>
          </div>
          <div class="confirm-modal-footer">
            <button type="button" class="btn btn-outline-secondary confirm-modal-cancel">إلغاء</button>
            <button type="button" class="btn btn-danger confirm-modal-confirm">حذف</button>
          </div>
        </div>
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const modal = document.getElementById('confirmحذفModal');
        const messageEl = document.getElementById('confirmحذفالرسالة');
        const closeButton = modal.querySelector('.confirm-modal-close');
        const cancelButton = modal.querySelector('.confirm-modal-cancel');
        const confirmButton = modal.querySelector('.confirm-modal-confirm');
        let activeForm = null;

        function openModal(message, form) {
          messageEl.textContent = message;
          activeForm = form;
          modal.classList.add('open');
          modal.setAttribute('aria-hidden', 'false');
        }

        function closeModal() {
          modal.classList.remove('open');
          modal.setAttribute('aria-hidden', 'true');
          activeForm = null;
        }

        document.querySelectorAll('.confirm-delete-button').forEach((button) => {
          button.addEventListener('click', function () {
            const itemLabel = button.dataset.item || 'this item';
            const message = `Are you sure you want to delete ${itemLabel}? This action cannot be undone.`;
            const form = button.closest('form');
            if (!form) return;
            openModal(message, form);
          });
        });

        closeButton.addEventListener('click', closeModal);
        cancelButton.addEventListener('click', closeModal);

        modal.addEventListener('click', function (event) {
          if (event.target === modal) {
            closeModal();
          }
        });

        confirmButton.addEventListener('click', function () {
          if (activeForm) {
            activeForm.submit();
          }
        });
      });
    </script>
  </body>
</html>
