<div class="page-heading mb-4">
  <div>
    <h2>المحادثة مع <%= contact.phone %></h2>
    <p class="text-muted">الحساب: <%= account.name %></p>
  </div>
</div>

<div class="chat-panel card p-4">
  <% if (messages.length === 0) { %>
    <div class="text-center text-muted py-5">ما كاين حتى رسالة.</div>
  <% } %>

  <% messages.forEach((message) => { %>
    <% if (message.direction === 'in') { %>
      <div class="chat-bubble-incoming">
        <div><%= message.message %></div>
        <small class="text-muted d-block mt-2"><%= message.created_at %></small>
      </div>
    <% } else { %>
      <div class="chat-bubble-outgoing">
        <div><%= message.message %></div>
        <small class="text-muted d-block mt-2"><%= message.created_at %></small>
      </div>
    <% } %>
  <% }); %>
</div>
